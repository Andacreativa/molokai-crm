generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── FATTURE ────────────────────────────────────────────────

model Cliente {
  id          Int       @id @default(autoincrement())
  nome        String
  cognome     String?
  email       String?
  telefono    String?
  dni         String?
  partitaIva  String?
  via         String?
  cap         String?
  citta       String?
  provincia   String?
  paese       String?   @default("Spagna")
  iban        String?
  note        String?
  tipo        String    @default("privato") // privato | azienda
  tipoImposta String    @default("IVA 21%") // IVA 21% | IVA Exenta
  createdAt   DateTime  @default(now())
  fatture     Fattura[]
}

model Fattura {
  id               Int       @id @default(autoincrement())
  numero           String?
  data             DateTime?
  scadenza         DateTime?
  clienteId        Int?
  cliente          Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  righe            String    // JSON: [{descrizione, quantita, prezzoUnitario}]
  baseImponibile   Float
  iva              Float     @default(21)
  totale           Float
  pagato           Boolean   @default(false)
  metodoPagamento  String?   // transferencia | tarjeta | bizum | efectivo
  mese             Int
  anno             Int       @default(2026)
  note             String?
  createdAt        DateTime  @default(now())
  spesa            Spesa?
}

// ─── SPESE ──────────────────────────────────────────────────

model Spesa {
  id              Int      @id @default(autoincrement())
  data            DateTime @default(now())
  fornitore       String
  categoria       String   // Scuola | Rappresentanza | Materiale Sportivo | Affitto | Utenze | Marketing | Assicurazione | Commercialista | Tasse | Altro
  descrizione     String?
  importo         Float
  ivaDeducibile   Boolean  @default(true)
  aliquotaIva     Float    @default(21)
  ivaRecuperabile Float    @default(0)
  mese            Int
  anno            Int      @default(2026)
  ricevutaPath    String?
  note            String?
  fatturaId       Int?     @unique
  fattura         Fattura? @relation(fields: [fatturaId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
}

model SpesaFissa {
  id            Int      @id @default(autoincrement())
  tipo          String
  categoria     String?
  cadenza       String   // mensile | annuale | trimestrale
  dataPagamento String
  costo         Float    @default(0)
  costoMensile  Float    @default(0)
  ordine        Int      @default(0)
  attiva        Boolean  @default(true)
  note          String?
  createdAt     DateTime @default(now())
}

// ─── CLUB (SOCI + BUONI) ────────────────────────────────────

model Socio {
  id                     Int               @id @default(autoincrement())
  nome                   String
  cognome                String?
  dni                    String?
  cellulare              String?
  email                  String?
  piano                  String            // PLAN VARADA | PLAN MATERIAL | ANNUALE | ALTRO
  pianoDescrizione       String?           // usato quando piano = "ALTRO"
  prezzoPiano            Float
  pagamento              String            @default("MENSILE") // MENSILE | ANNUALE
  iban                   String?
  stato                  String            @default("ATTIVO") // ATTIVO | SOSPESO | CANCELLATO
  matricola              String?
  matricolaImporto       Float             @default(50)
  matricolaGratuita      Boolean           @default(false)
  matricolaPagata        Boolean           @default(false)
  matricolaMesePagamento String?
  note                   String?
  createdAt              DateTime          @default(now())
  pagamentiMensili       PagamentoSocio[]
  buoni                  Buono[]
}

model PagamentoSocio {
  id        Int      @id @default(autoincrement())
  socioId   Int
  socio     Socio    @relation(fields: [socioId], references: [id], onDelete: Cascade)
  anno      Int
  mese      Int      // 1-12
  pagato    Boolean  @default(false)
  importo   Float?
  data      DateTime?
  createdAt DateTime @default(now())

  @@unique([socioId, anno, mese])
}

model Buono {
  id             Int      @id @default(autoincrement())
  nome           String
  cognome        String?
  cellulare      String?
  email          String?
  socioId        Int?
  socio          Socio?   @relation(fields: [socioId], references: [id], onDelete: SetNull)
  tipoBuono      String   // BONO CLASE | PACK 4 SUP | PACK 8 SUP | CUSTOM
  prezzoBuono    Float
  pagato         Boolean  @default(false)
  mesePagamento  String?
  stato          String   @default("Attivo") // Attivo | Usato | Scaduto
  sessioniTotali Int?
  sessioniUsate  Int      @default(0)
  note           String?
  createdAt      DateTime @default(now())
}

// ─── PRENOTAZIONI ───────────────────────────────────────────

model PrenotazioneFareHarbor {
  id       Int   @id @default(autoincrement())
  anno     Int   @default(2026)
  mese     Int
  sett1    Float @default(0)
  sett2    Float @default(0)
  sett3    Float @default(0)
  sett4    Float @default(0)
  totale   Float @default(0)

  @@unique([anno, mese])
}

model FareHarborConfig {
  id            Int      @id @default(autoincrement())
  anno          Int      @unique
  refundReserve Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model PrenotazioneStripe {
  id           Int   @id @default(autoincrement())
  anno         Int   @default(2026)
  mese         Int
  lordo        Float @default(0)
  commissioni  Float @default(0)
  rimborsi     Float @default(0)
  netto        Float @default(0)

  @@unique([anno, mese])
}

model PrenotazioneGetYourGuide {
  id           Int   @id @default(autoincrement())
  anno         Int   @default(2026)
  mese         Int
  lordo        Float @default(0)
  commissioni  Float @default(0)
  netto        Float @default(0)

  @@unique([anno, mese])
}

model PagamentoInScuola {
  id            Int      @id @default(autoincrement())
  data          DateTime @unique
  mese          Int
  anno          Int      @default(2026)
  totaleGiorno  Float    @default(0)  // SALE dal CSV
  totVendite    Float    @default(0)  // TOTALSALES dal CSV
  rimborsi      Float    @default(0)  // REFUND dal CSV
  note          String?
  createdAt     DateTime @default(now())
}

// ─── GRUPPI ─────────────────────────────────────────────────

model Gruppo {
  id            Int       @id @default(autoincrement())
  nome          String    // es: Colegio La Salle Barceloneta
  tipo          String    @default("scuola") // scuola | azienda | altro
  contatto      String?
  email         String?
  telefono      String?
  note          String?
  createdAt     DateTime  @default(now())
  sessioni      SessioneGruppo[]
}

model SessioneGruppo {
  id             Int      @id @default(autoincrement())
  gruppoId       Int
  gruppo         Gruppo   @relation(fields: [gruppoId], references: [id], onDelete: Cascade)
  data           DateTime
  mese           Int
  anno           Int      @default(2026)
  partecipanti   Int
  prezzoPP       Float
  totale         Float    // calcolato: partecipanti * prezzoPP
  incassato      Boolean  @default(false)
  note           String?
  createdAt      DateTime @default(now())
}

// ─── COLLABORATORI ──────────────────────────────────────────

model Collaboratore {
  id          Int                      @id @default(autoincrement())
  nome        String
  cognome     String?
  dni         String?
  cellulare   String?
  email       String?
  iban        String?
  ruolo       String                   // Istruttore Surf | Istruttore SUP | Insegnante Yoga | Fotografo | Receptionist | Altro
  note        String?
  attivo      Boolean                  @default(true)
  tariffe     TariffaCollaboratore[]
  sessioni    SessioneCollaboratore[]
  pagamenti   PagamentoCollaboratore[]
  anticipi    AnticipoColl[]
  createdAt   DateTime                 @default(now())
}

model TariffaCollaboratore {
  id               Int           @id @default(autoincrement())
  collaboratoreId  Int
  collaboratore    Collaboratore @relation(fields: [collaboratoreId], references: [id], onDelete: Cascade)
  tipoAttivita     String        // Classe Gruppo | Classe Singola | Sessione Yoga | Giornata | Altro
  tariffaOraria    Float
  createdAt        DateTime      @default(now())

  @@unique([collaboratoreId, tipoAttivita])
}

model SessioneCollaboratore {
  id               Int           @id @default(autoincrement())
  collaboratoreId  Int
  collaboratore    Collaboratore @relation(fields: [collaboratoreId], references: [id], onDelete: Cascade)
  data             DateTime
  mese             Int
  anno             Int           @default(2026)
  tipoAttivita     String
  ore              Float
  costo            Float         // ore * tariffa
  note             String?
  createdAt        DateTime      @default(now())
}

model PagamentoCollaboratore {
  id               Int           @id @default(autoincrement())
  collaboratoreId  Int
  collaboratore    Collaboratore @relation(fields: [collaboratoreId], references: [id], onDelete: Cascade)
  anno             Int
  mese             Int
  dovuto           Float
  pagato           Float         @default(0)
  data             DateTime?
  note             String?
  createdAt        DateTime      @default(now())

  @@unique([collaboratoreId, anno, mese])
}

model AnticipoColl {
  id               Int           @id @default(autoincrement())
  collaboratoreId  Int
  collaboratore    Collaboratore @relation(fields: [collaboratoreId], references: [id], onDelete: Cascade)
  mese             String
  importo          Float
  restituito       Boolean       @default(false)
  createdAt        DateTime      @default(now())
}

// ─── DIPENDENTI ─────────────────────────────────────────────

model Dipendente {
  id               Int                    @id @default(autoincrement())
  nome             String
  cognome          String?
  ruolo            String?
  dataNascita      DateTime?
  dni              String?
  nie              String?
  via              String?
  cap              String?
  citta            String?
  provincia        String?
  paese            String?                @default("Spagna")
  telefono         String?
  email            String?
  iban             String?
  fotoPath         String?
  nettoBustaPaga   Float                  @default(0)
  irpf             Float                  @default(0)
  irpfImporto      Float                  @default(0)
  seguridadSocial  Float                  @default(0)
  createdAt        DateTime               @default(now())
  pagamenti        PagamentoDipendente[]
}

model PagamentoDipendente {
  id            Int        @id @default(autoincrement())
  dipendenteId  Int
  dipendente    Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  anno          Int
  mese          Int
  tipo          String     // stipendio | seguridad
  spesaId       Int?       // collegamento a Spesa creata automaticamente al toggle
  createdAt     DateTime   @default(now())

  @@unique([dipendenteId, anno, mese, tipo])
}

// ─── INVENTARIO ─────────────────────────────────────────────

model CategoriaInventario {
  id        Int              @id @default(autoincrement())
  nome      String           @unique
  ordine    Int              @default(0)
  createdAt DateTime         @default(now())
  items     InventarioItem[]
}

model InventarioItem {
  id            Int                 @id @default(autoincrement())
  categoriaId   Int
  categoria     CategoriaInventario @relation(fields: [categoriaId], references: [id], onDelete: Cascade)
  marca         String?
  modello       String?
  taglia        String?
  lunghezza     String?
  volume        String?
  numeroSerie   String?
  colore        String?
  quantita      Int                 @default(1)
  stato         String              @default("Nuovo")
  note          String?
  dataAcquisto  DateTime?
  costoAcquisto Float?
  createdAt     DateTime            @default(now())
}

// ─── ALTRI INGRESSI ─────────────────────────────────────────

model AltroIngresso {
  id          Int       @id @default(autoincrement())
  fonte       String
  descrizione String?
  mese        Int
  anno        Int       @default(2026)
  importo     Float
  incassato   Boolean   @default(false)
  dataIncasso DateTime?
  createdAt   DateTime  @default(now())
}

// ─── PRODOTTI ───────────────────────────────────────────────

model Prodotto {
  id              Int             @id @default(autoincrement())
  nome            String
  categoria       String          // Esperienza | Lezione | Noleggio | Pack | Abbonamento
  prezzoVendita   Float
  costodiretto    Float           @default(0)  // costo collaboratore + materiale
  margine         Float           @default(0)  // calcolato: prezzoVendita - costodiretto
  canale          String          @default("FareHarbor") // FareHarbor | GYG | Cassa | Stripe | Diretto
  durata          String?         // es: 1h30
  stato           String          @default("Attivo") // Attivo | NonListato | Archiviato
  note            String?
  createdAt       DateTime        @default(now())
  vendite         VenditaProdotto[]
}

model VenditaProdotto {
  id          Int      @id @default(autoincrement())
  prodottoId  Int
  prodotto    Prodotto @relation(fields: [prodottoId], references: [id], onDelete: Cascade)
  data        DateTime
  mese        Int
  anno        Int      @default(2026)
  quantita    Int      @default(1)
  importo     Float
  canale      String?
  note        String?
  createdAt   DateTime @default(now())
}
