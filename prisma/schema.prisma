generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Cliente {
  id          Int       @id @default(autoincrement())
  nome        String
  paese       String    @default("Italia")
  email       String?
  telefono    String?
  partitaIva  String?
  via         String?
  cap         String?
  citta       String?
  provincia   String?
  note        String?
  createdAt   DateTime  @default(now())
  fatture     Fattura[]
}

model Fattura {
  id          Int      @id @default(autoincrement())
  clienteId   Int?
  cliente     Cliente? @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  azienda     String   @default("Spagna")
  aziendaNota String?
  descrizione String?
  mese        Int
  anno        Int      @default(2025)
  importo     Float
  tipoIva     String   @default("iva")
  iva         Float    @default(21)
  pagato      Boolean  @default(false)
  scadenza    DateTime?
  createdAt   DateTime @default(now())
}

model AltroIngresso {
  id          Int      @id @default(autoincrement())
  fonte       String
  azienda     String   @default("Spagna")
  aziendaNota String?
  descrizione String?
  mese        Int
  anno        Int      @default(2025)
  importo     Float
  incassato   Boolean  @default(false)
  dataIncasso DateTime?
  createdAt   DateTime @default(now())
}

model SpesaFissa {
  id            Int      @id @default(autoincrement())
  tipo          String
  cadenza       String
  dataPagamento String
  costo         Float    @default(0)
  costoMensile  Float    @default(0)
  ordine        Int      @default(0)
  createdAt     DateTime @default(now())
}

model Spesa {
  id           Int      @id @default(autoincrement())
  azienda      String   @default("Spagna")
  aziendaNota  String?
  fornitore    String
  fornitoreId  Int?
  categoria    String
  descrizione  String?
  note         String?
  ricevutaPath String?
  mese         Int
  anno         Int      @default(2025)
  importo      Float
  createdAt    DateTime @default(now())
}

model Fornitore {
  id          Int      @id @default(autoincrement())
  nome        String
  paese       String   @default("Italia")
  email       String?
  telefono    String?
  partitaIva  String?
  via         String?
  cap         String?
  citta       String?
  provincia   String?
  note        String?
  createdAt   DateTime @default(now())
}

model Dipendente {
  id               Int       @id @default(autoincrement())
  nome             String
  cognome          String?
  ruolo            String?
  dataNascita      DateTime?
  dni              String?
  nie              String?
  via              String?
  cap              String?
  citta            String?
  provincia        String?
  paese            String?   @default("Spagna")
  telefono         String?
  email            String?
  iban             String?
  nettoBustaPaga   Float     @default(0)
  irpf             Float     @default(0)
  seguridadSocial  Float     @default(0)
  createdAt        DateTime  @default(now())
  pagamenti        PagamentoDipendente[]
}

model PagamentoDipendente {
  id            Int        @id @default(autoincrement())
  dipendenteId  Int
  dipendente    Dipendente @relation(fields: [dipendenteId], references: [id], onDelete: Cascade)
  anno          Int
  mese          Int
  tipo          String     // 'stipendio' | 'seguridad'
  spesaId       Int?
  createdAt     DateTime   @default(now())

  @@unique([dipendenteId, anno, mese, tipo])
}

model Contatto {
  id         Int      @id @default(autoincrement())
  nome       String
  paese      String   @default("Italia")
  email      String?
  telefono   String?
  partitaIva String?
  via        String?
  cap        String?
  citta      String?
  provincia  String?
  note       String?
  status     String   @default("lead")
  createdAt  DateTime @default(now())
}

model Lead {
  id         Int           @id @default(autoincrement())
  nome       String
  azienda    String?
  email      String?
  telefono   String?
  valore     Float?
  stage      String        @default("nuovo")
  note       String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  appunti    AppuntoCall[]
  preventivi Preventivo[]
}

model AppuntoCall {
  id        Int      @id @default(autoincrement())
  leadId    Int
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  testo     String
  createdAt DateTime @default(now())
}

model Preventivo {
  id             Int       @id @default(autoincrement())
  numero         String
  nomeCliente    String
  emailCliente   String?
  aziendaCliente String?
  azienda        String    @default("Spagna")
  oggetto        String
  voci           String
  iva            Float     @default(21)
  subtotale      Float     @default(0)
  totale         Float     @default(0)
  feeCommerciale Float     @default(0)
  leadId         Int?
  lead           Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  status         String    @default("attesa")
  note           String?
  condizioni     String?
  dataScadenza   DateTime?
  createdAt      DateTime  @default(now())
}
